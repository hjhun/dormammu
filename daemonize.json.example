{
  "schema_version": 1,
  "prompt_path": "./queue/prompts",
  "result_path": "./queue/results",
  "watch": {
    "backend": "auto",
    "poll_interval_seconds": 60,
    "settle_seconds": 0
  },
  "queue": {
    "allowed_extensions": [".md", ".txt"],
    "ignore_hidden_files": true
  },
  "phases": {
    "plan": {
      "skill_path": "~/.dormammu/agents/skills/planning-agent/SKILL.md",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    },
    "design": {
      "skill_path": "~/.dormammu/agents/skills/designing-agent/SKILL.md",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    },
    "develop": {
      "skill_path": "~/.dormammu/agents/skills/developing-agent/SKILL.md",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    },
    "build_and_deploy": {
      "skill_path": "~/.dormammu/agents/skills/building-and-deploying/SKILL.md",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    },
    "test_and_review": {
      "skill_path": "~/.dormammu/agents/skills/testing-and-reviewing/SKILL.md",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    },
    "commit": {
      "skill_path": "~/.dormammu/agents/skills/committing-agent/SKILL.md",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    }
  }
}
