{
  "active_agent_cli": "/home/you/.local/bin/codex",
  "fallback_agent_clis": [
    "claude",
    {
      "path": "aider",
      "extra_args": ["--yes"]
    }
  ],
  "cli_overrides": {
    "cline": {
      "extra_args": ["-y", "--verbose", "--timeout", "1200"]
    }
  },
  "token_exhaustion_patterns": [
    "usage limit",
    "quota exceeded",
    "rate limit exceeded",
    "token limit",
    "insufficient credits"
  ],
  "agents": {
    "developer": {
      "cli": "claude",
      "model": "claude-opus-4-6"
    },
    "tester": {
      "cli": "claude",
      "model": "claude-sonnet-4-6"
    },
    "reviewer": {
      "cli": "claude",
      "model": "claude-sonnet-4-6"
    },
    "committer": {
      "cli": "claude"
    }
  }
}
