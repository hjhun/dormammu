{
  "schema_version": 1,
  "prompt_path": "./queue/prompts",
  "result_path": "./queue/results",
  "watch": {
    "backend": "auto",
    "poll_interval_seconds": 60,
    "settle_seconds": 2
  },
  "queue": {
    "allowed_extensions": [".md"],
    "ignore_hidden_files": true
  },
  "phases": {
    "plan": {
      "skill_name": "planning-agent",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    },
    "design": {
      "skill_path": "./custom-skills/review-design.md",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    },
    "develop": {
      "skill_name": "developing-agent",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    },
    "build_and_deploy": {
      "skill_path": "~/.dormammu/agents/skills/building-and-deploying/SKILL.md",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    },
    "test_and_review": {
      "skill_name": "testing-and-reviewing",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    },
    "commit": {
      "skill_name": "committing-agent",
      "agent_cli": {
        "path": "codex",
        "input_mode": "auto",
        "prompt_flag": null,
        "extra_args": []
      }
    }
  }
}
